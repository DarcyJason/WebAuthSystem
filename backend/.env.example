# No need to replace it
SERVER__IS_DEVELOPMENT_MODE=true

# No need to replace it
SERVER__FRONTEND_ADDRESS="http://localhost:5173"

# No need to replace it
SERVER__BACKEND_IP="0.0.0.0"

# No need to replace it
SERVER__BACKEND_PORT=7878

# replace its value by running "openssl rand -base64 64" in your terminal
# For example
# JWT__SECRET="***"
JWT__SECRET="your_jwt_secret"

# Access token TTL in seconds (default: 3600 = 1 hour)
JWT__EXPIRES_IN_SECONDS=3600

# Refresh token TTL in days (default: 7)
JWT__REFRESH_TOKEN_EXPIRES_IN_DAYS=7

# Email verification token TTL in seconds (default: 86400 = 24 hours)
JWT__EMAIL_VERIFY_EXPIRES_IN_SECONDS=86400

# Password reset token TTL in seconds (default: 3600 = 1 hour)
JWT__PASSWORD_RESET_EXPIRES_IN_SECONDS=3600

# replace its value, you can get the api key from https://resend.com/api-keys
# For example
# JWT__SECRET="re_***"
RESEND__API_KEY="re_your_resend_api_key"

# replace its value, keep your_domain as same as what you set in https://resend.com/domains
# For example
# RESEND__SYSTEM_OWNER_EMAIL="your_email_prefix@example.com"
RESEND__SYSTEM_OWNER_EMAIL="your_email_prefix@your_domain"

# Only need to replace the user and password
# Don't change localhost to postgres
# For example
# POSTGRES__DATABASE_URL=postgres://your_postgres_user_name:your_postgres_password@localhost/web_auth_system
POSTGRES__DATABASE_URL="postgres://postgres:postgres@localhost/web_auth_system"

# Replace its value, keep its value as same as POSTGRES__DATABASE_URL
# Don't change localhost to postgres
# For example
# DATABASE_URL=postgres://your_postgres_user_name:your_postgres_password@postgres/web_auth_system
DATABASE_URL="postgres://postgres:postgres@localhost/web_auth_system"

# No need to replace it
REDIS__ADDRESS="redis://localhost:6379"
