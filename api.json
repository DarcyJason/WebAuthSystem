{
  "openapi": "3.1.0",
  "info": {
    "title": "WebAuthSystem API",
    "description": "",
    "license": {
      "name": ""
    },
    "version": "1.0.0"
  },
  "paths": {
    "/api/v1/auth/forgot-password": {
      "post": {
        "tags": ["Auth"],
        "operationId": "forgot_password_handler",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ForgotPasswordRequestPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "If the email is registered, a password reset link has been sent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForgotPasswordResponseData"
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "tags": ["Auth"],
        "operationId": "login_handler",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequestPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Login successful — access token in Authorization header, refresh token in Set-Cookie",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponseData"
                }
              }
            }
          },
          "400": {
            "description": "Invalid credentials or email not verified"
          },
          "404": {
            "description": "User not found"
          }
        }
      }
    },
    "/api/v1/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "operationId": "logout_handler",
        "responses": {
          "200": {
            "description": "Logged out — refresh token cookie cleared",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LogoutResponseData"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ]
      }
    },
    "/api/v1/auth/register": {
      "post": {
        "tags": ["Auth"],
        "operationId": "register_handler",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequestPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Registered successfully, verification email sent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterResponseData"
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          },
          "409": {
            "description": "User already exists"
          }
        }
      }
    },
    "/api/v1/auth/resend-verification": {
      "post": {
        "tags": ["Auth"],
        "operationId": "resend_verification_handler",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResendVerificationRequestPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Verification email sent if user exists and is not verified",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResendVerificationResponseData"
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          }
        }
      }
    },
    "/api/v1/auth/reset-password": {
      "post": {
        "tags": ["Auth"],
        "operationId": "reset_password_handler",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResetPasswordRequestPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Password reset successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResetPasswordResponseData"
                }
              }
            }
          },
          "400": {
            "description": "Token expired, already used, or passwords do not match"
          },
          "404": {
            "description": "Token not found"
          }
        }
      }
    },
    "/api/v1/auth/rotate-refresh-token": {
      "post": {
        "tags": ["Auth"],
        "operationId": "rotate_refresh_token_handler",
        "responses": {
          "200": {
            "description": "New access token in Authorization header, new refresh token in Set-Cookie",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RotateRefreshTokenResponseData"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid refresh token cookie"
          }
        }
      }
    },
    "/api/v1/auth/verify": {
      "post": {
        "tags": ["Auth"],
        "operationId": "verify_handler",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyRequestPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Email verified, account activated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerifyResponseData"
                }
              }
            }
          },
          "400": {
            "description": "Token expired or already used"
          },
          "404": {
            "description": "Token not found"
          }
        }
      }
    },
    "/api/v1/protected/change-password": {
      "post": {
        "tags": ["User"],
        "operationId": "change_password_handler",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangePasswordRequestPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Password changed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChangePasswordResponseData"
                }
              }
            }
          },
          "400": {
            "description": "Invalid current password or passwords do not match"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ]
      }
    },
    "/api/v1/protected/me": {
      "get": {
        "tags": ["User"],
        "operationId": "get_me_handler",
        "responses": {
          "200": {
            "description": "Current authenticated user info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetMeResponseData"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "ChangePasswordRequestPayload": {
        "type": "object",
        "required": ["currentPassword", "newPassword", "confirmPassword"],
        "properties": {
          "confirmPassword": {
            "type": "string"
          },
          "currentPassword": {
            "type": "string"
          },
          "newPassword": {
            "type": "string"
          }
        }
      },
      "ChangePasswordResponseData": {
        "default": null
      },
      "ForgotPasswordRequestPayload": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": {
            "type": "string"
          }
        }
      },
      "ForgotPasswordResponseData": {
        "default": null
      },
      "GetMeResponseData": {
        "type": "object",
        "required": ["userId", "name", "email", "status"],
        "properties": {
          "email": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          }
        }
      },
      "LoginRequestPayload": {
        "type": "object",
        "required": ["nameOrEmail", "password"],
        "properties": {
          "nameOrEmail": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "LoginResponseData": {
        "default": null
      },
      "LogoutResponseData": {
        "type": "object"
      },
      "RegisterRequestPayload": {
        "type": "object",
        "required": ["name", "email", "password", "confirmPassword"],
        "properties": {
          "confirmPassword": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "RegisterResponseData": {
        "type": "object",
        "required": ["userId"],
        "properties": {
          "userId": {
            "type": "string"
          }
        }
      },
      "ResendVerificationRequestPayload": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": {
            "type": "string"
          }
        }
      },
      "ResendVerificationResponseData": {
        "default": null
      },
      "ResetPasswordRequestPayload": {
        "type": "object",
        "required": ["token", "newPassword", "confirmPassword"],
        "properties": {
          "confirmPassword": {
            "type": "string"
          },
          "newPassword": {
            "type": "string"
          },
          "token": {
            "type": "string"
          }
        }
      },
      "ResetPasswordResponseData": {
        "default": null
      },
      "RotateRefreshTokenResponseData": {
        "type": "object",
        "required": ["token_type"],
        "properties": {
          "token_type": {
            "type": "string"
          }
        }
      },
      "VerifyRequestPayload": {
        "type": "object",
        "required": ["token"],
        "properties": {
          "token": {
            "type": "string"
          }
        }
      },
      "VerifyResponseData": {
        "default": null
      }
    },
    "securitySchemes": {
      "bearer_auth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "tags": [
    {
      "name": "Auth",
      "description": "Authentication endpoints"
    },
    {
      "name": "User",
      "description": "User management endpoints"
    }
  ]
}
